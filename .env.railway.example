# Environment
ENV=production
DEBUG=0

# Django
SECRET_KEY=your-secret-key-here
DATABASE_URL=postgresql://user:password@host:port/database
APP_BASE_URL=https://your-app.up.railway.app

# Security
ALLOWED_HOSTS=your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
SITE_ID=1
SITE_DOMAIN=your-app.up.railway.app
LOG_LEVEL=INFO

# Cloudflare R2 Storage
AWS_ACCESS_KEY_ID=your-r2-access-key
AWS_SECRET_ACCESS_KEY=your-r2-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=auto
AWS_S3_ADDRESSING_STYLE=virtual

# Backup hardening
BACKUP_FERNET_KEY=
BACKUP_WEBHOOK_TOKEN=

# Google OAuth2
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional; if omitted, settings derives it from APP_BASE_URL or RAILWAY_PUBLIC_DOMAIN.
# GOOGLE_REDIRECT_URI=https://your-app.up.railway.app/accounts/google/login/callback/
# GOOGLE_HOSTED_DOMAIN=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=